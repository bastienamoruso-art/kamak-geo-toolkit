# Copiez ce fichier en .env et remplissez avec vos cles API.
# Le fichier .env est dans .gitignore, vos cles ne seront jamais committees.

# OpenAI (https://platform.openai.com/api-keys)
# Coût indicatif : gpt-4o-mini = ~0.15 $ / 1M tokens input, 0.60 $ / 1M output
OPENAI_API_KEY=sk-...

# Anthropic (https://console.anthropic.com/settings/keys)
# Coût indicatif : claude-sonnet-4-5 = ~3 $ / 1M tokens input, 15 $ / 1M output
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity (https://www.perplexity.ai/settings/api)
# Coût indicatif : sonar = ~1 $ / 1M tokens + 5 $ / 1000 requêtes
# C'est le seul modèle de cette liste qui fait du search retrieval temps réel.
PERPLEXITY_API_KEY=pplx-...

# Google Gemini (https://aistudio.google.com/app/apikey)
# Coût indicatif : gemini-2.5-flash = ~0.075 $ / 1M tokens input, 0.30 $ / 1M output
# Quota gratuit généreux disponible sur AI Studio.
GEMINI_API_KEY=...

# Mistral (https://console.mistral.ai/api-keys/)
# Coût indicatif : mistral-large-latest = ~2 $ / 1M tokens input, 6 $ / 1M output
MISTRAL_API_KEY=...
